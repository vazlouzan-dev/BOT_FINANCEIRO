# Financial Market Bias Analyzer - Environment Configuration
# Copy this file to .env and fill in your API keys (never commit .env to git)

# ============================================================================
# FRED API (Federal Reserve Economic Data) - historical indicators
# Register for FREE at: https://fred.stlouisfed.org/docs/api/api_key.html
# ============================================================================
FRED_API_KEY=your_fred_api_key_here

# ============================================================================
# FINNHUB API - upcoming economic calendar with real forecasts & previous values
# Register for FREE at: https://finnhub.io/register
# Free tier includes economic calendar endpoint (no credit card needed)
# ============================================================================
FINNHUB_API_KEY=your_finnhub_api_key_here


# ============================================================================
# OPTIONAL: Logging settings
# ============================================================================
# LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
# VERBOSE=True
